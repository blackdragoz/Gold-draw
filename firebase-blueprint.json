{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "collections": {
    "users": {
      "descriptor": "Stores user profiles with coin counts and admin flag",
      "schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "name": { "type": "string" },
          "photoURL": { "type": "string" },
          "isAdmin": { "type": "boolean" },
          "goldCoins": { "type": "integer" }
        },
        "required": ["email", "name", "photoURL", "isAdmin"]
      }
    },
    "tickets": {
      "descriptor": "Stores user booked numbers, payment details, and approval status",
      "schema": {
        "type": "object",
        "properties": {
          "number": { "type": "string" },
          "userEmail": { "type": "string" },
          "userName": { "type": "string" },
          "userAvatar": { "type": "string" },
          "paymentMethod": { "type": "string" },
          "paymentId": { "type": "string" },
          "txnId": { "type": "string" },
          "status": { "type": "string" },
          "createdAt": { "type": "string" }
        },
        "required": ["number", "userEmail", "userName", "paymentMethod", "paymentId", "txnId", "status", "createdAt"]
      }
    },
    "drawState": {
      "descriptor": "Global dynamic live draw sync document",
      "schema": {
        "type": "object",
        "properties": {
          "winningNumber": { "type": "string" },
          "isRolling": { "type": "boolean" },
          "lastDrawnAt": { "type": "string" }
        },
        "required": ["winningNumber", "isRolling"]
      }
    },
    "pastWinners": {
      "descriptor": "Past drawing result logs for global display",
      "schema": {
        "type": "object",
        "properties": {
          "winningNumber": { "type": "string" },
          "drawnAt": { "type": "string" }
        },
        "required": ["winningNumber", "drawnAt"]
      }
    },
    "coinTransactions": {
      "descriptor": "Logs coin balance updates (rewards, referrals, ticket booking deductions)",
      "schema": {
        "type": "object",
        "properties": {
          "userEmail": { "type": "string" },
          "amount": { "type": "integer" },
          "reason": { "type": "string" },
          "timestamp": { "type": "string" }
        },
        "required": ["userEmail", "amount", "reason", "timestamp"]
      }
    }
  }
}
